# 1212 API — variables de entorno. Copiar a .env (NO versionar .env).

# Neon Postgres (connection string con sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# JWT (access tokens). Generar secreto largo aleatorio.
JWT_SECRET="cambiar-por-secreto-largo-aleatorio"
JWT_ACCESS_TTL="900"        # 15 min en segundos
REFRESH_TTL_DAYS="30"

# OAuth — Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — Apple
APPLE_CLIENT_ID=""          # Services ID
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""        # contenido del .p8 (con \n escapados)

# Cloudflare R2 (storage de media — opcional; sin esto /media devuelve 503)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="1212-media"
R2_PUBLIC_BASE=""           # p.ej. https://media.tudominio.com

# App
PORT="8787"
NODE_ENV="development"
ALLOWED_ORIGINS="exp://,http://localhost:8081"
